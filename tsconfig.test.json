{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "incremental": false,
    "isolatedModules": false,
    "jsx": "react-jsx",
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "lib/api-query.ts",
    "lib/auth/line.ts",
    "lib/auth/line-session.ts",
    "lib/auth/session.ts",
    "lib/auth/types.ts",
    "lib/db/environment.ts",
    "lib/db/postgres.ts",
    "lib/bookmark-requests.ts",
    "lib/bookmark-route-handlers.ts",
    "lib/bookmarks.ts",
    "lib/class-detail.ts",
    "lib/class-detail-dto.ts",
    "lib/class-detail-requests.ts",
    "lib/class-detail-route-handlers.ts",
    "lib/job-dto.ts",
    "lib/jobs.ts",
    "lib/profile.ts",
    "lib/personal-timetable.ts",
    "lib/saved-items.ts",
    "lib/security/rate-limit.ts",
    "lib/security/request.ts",
    "lib/security/url.ts",
    "lib/timetable-core.ts",
    "lib/timetable-dto.ts",
    "lib/timetable-requests.ts",
    "lib/timetable-route-handlers.ts",
    "tests/**/*.test.ts"
  ],
  "exclude": ["node_modules", ".next", ".test-dist"]
}
