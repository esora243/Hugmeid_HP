# Copy this file to `.env.local` when setting up local development.
# This is a template only. Do not put real secrets in this file.

NEXT_PUBLIC_APP_NAME=Hugmeid
NEXT_PUBLIC_APP_DESCRIPTION=医学生向けプラットフォーム
NEXT_PUBLIC_SITE_URL=http://localhost:3000
IMAGE_ALLOWED_REMOTE_HOSTS=storage.googleapis.com

# Runtime environment labels used to prevent staging and production database mixups.
# Local development may omit these; Cloud Run staging/production must set both.
# Cloud SQL must also contain app_environment.database_environment with the same value.
HUGMEID_DEPLOY_ENV=local
HUGMEID_DATABASE_ENV=local

# Cloud SQL PostgreSQL connection used by Next.js Route Handlers.
# In Cloud Run, mount the instance and use PGHOST=/cloudsql/<connection-name>.
# Use separate staging and production Cloud SQL database credentials.
CLOUD_SQL_CONNECTION_NAME=
PGHOST=
PGPORT=5432
PGDATABASE=hugmeid
PGUSER=hugmeid_app
PGPASSWORD=
PGPOOL_MAX=5

# LIFF app id used by @line/liff in the browser.
# Use separate LINE Login channels and LIFF apps for staging and production.
NEXT_PUBLIC_LIFF_ID=

# Optional external LINE Login URL used outside the LIFF client flow.
NEXT_PUBLIC_LINE_LOGIN_URL=

# LINE Login channel credentials used only by server-side token verification.
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# Messaging API access token. Server-only; future push delivery jobs use this.
LINE_CHANNEL_ACCESS_TOKEN=

# Signed httpOnly application session cookie secret. Required in production.
SESSION_SECRET=

# External links used while CMS/API integration is incomplete.
NEXT_PUBLIC_DEFAULT_APPLY_URL=
NEXT_PUBLIC_SYLLABUS_URL=
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com
